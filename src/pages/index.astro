---
import ContactForm from "../components/ContactForm.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { createSiteConfig } from "../data/site.js";
import BaseLayout from "../layouts/BaseLayout.astro";

const withBase = (path) => {
  if (typeof path !== "string" || !path.startsWith("/")) {
    return path;
  }

  return `${import.meta.env.BASE_URL}${path.slice(1)}`;
};

const site = createSiteConfig(import.meta.env.PUBLIC_CONTACT_WEBHOOK_URL ?? "");

site.hero.video = withBase(site.hero.video);
site.hero.poster = withBase(site.hero.poster);
site.services = site.services.map((item) => ({
  ...item,
  icon: withBase(item.icon),
}));
site.approach.image = withBase(site.approach.image);

const logoSrc = withBase("/source-assets/media/mc2tek-logo.png");
const seoImage = withBase("/source-assets/video/d36175f4549276e09bf8bac02ef5958f.jpg");
const currentYear = new Date().getFullYear();
---

<BaseLayout title={site.brand.legalName} description={site.brand.description} image={seoImage}>
  <a id="top"></a>
  <SiteHeader brand={site.brand} nav={site.nav} logoSrc={logoSrc} />

  <main>
    <section class="hero-section">
      <div class="hero-media-shell" aria-hidden="true">
        <video autoplay muted loop playsinline poster={site.hero.poster}>
          <source src={site.hero.video} type="video/mp4" />
        </video>
      </div>

      <div class="hero-noise" aria-hidden="true"></div>

      <div class="shell hero-grid">
        <div class="hero-copy">
          <h1>{site.hero.title}</h1>
          <p class="hero-intro">{site.hero.intro}</p>

          <div class="hero-actions">
            <a class="button" href={site.hero.primaryCta.href}>{site.hero.primaryCta.label}</a>
            <a class="button button-ghost light" href={site.hero.secondaryCta.href}>
              {site.hero.secondaryCta.label}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section light-section" id="servizi">
      <div class="shell section-head">
        <div>
          <span class="eyebrow">Servizi</span>
          <h2>Competenze integrate per progettare impianti sicuri, efficienti e coordinati, anche in BIM.</h2>
        </div>
        <p>
          MC² TEK sviluppa progetti integrati per impianti meccanici, elettrici, speciali e antincendio, seguendo ogni intervento dallo studio preliminare alla direzione lavori. Un unico interlocutore tecnico per coordinare prestazioni, sicurezza, sostenibilità e rispetto delle normative.
        </p>
      </div>

      <div class="shell service-grid">
        {site.services.map((service, index) => (
          <article class="service-card">
            <div class="service-topline">
              <span class="service-index">0{index + 1}</span>
              <img class="service-icon" src={service.icon} alt="" loading="lazy" />
            </div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section dark-section" id="metodo">
      <div class="shell method-grid">
        <div class="method-copy">
          <span class="eyebrow">{site.approach.eyebrow}</span>
          <h2>{site.approach.title}</h2>
          <p>{site.approach.intro}</p>

          <div class="pillar-grid">
            {site.approach.pillars.map((pillar, index) => (
              <article class="pillar-card">
                <span class="pillar-step">{pillar.step}</span>
                <h3>{pillar.title}</h3>
                <p>{pillar.text}</p>
                {index < site.approach.pillars.length - 1 && <span class="pillar-connector" aria-hidden="true"></span>}
              </article>
            ))}
          </div>
        </div>

        <div class="method-visual" aria-hidden="true">
          <img src={site.approach.image} alt="" loading="lazy" />
        </div>
      </div>
    </section>

    <section class="section contact-section" id="contatti">
      <div class="shell contact-grid">
        <div class="contact-copy">
          <span class="eyebrow">{site.contact.eyebrow}</span>
          <h2>{site.contact.title}</h2>
          <p>{site.contact.intro}</p>

          <div class="contact-stack">
            <article class="contact-card">
              <span>Sede</span>
              <strong>{site.brand.address}</strong>
              <a href={site.brand.mapsUrl} target="_blank" rel="noreferrer">
                Apri Google Maps
              </a>
            </article>

            <article class="contact-card">
              <span>Riferimenti</span>
              <strong>
                <a href={`mailto:${site.brand.email}`}>{site.brand.email}</a>
              </strong>
              <strong>
                <a href={`tel:${site.brand.phone.replaceAll("/", "")}`}>Tel. {site.brand.phone}</a>
              </strong>
              <strong>
                <a href={`tel:${site.brand.mobile.replaceAll("-", "")}`}>Cell. {site.brand.mobile}</a>
              </strong>
            </article>

            <article class="contact-card">
              <span>Impresa</span>
              <strong>Partita IVA {site.brand.vat}</strong>
              <p>GitHub Pages in hosting statico. Webhook form configurabile in deploy.</p>
            </article>
          </div>
        </div>

        <ContactForm contact={site.contact} />
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="shell footer-inner">
      <div class="footer-brand">
        <a class="footer-brand-link" href="#top" aria-label={`Vai all'inizio di ${site.brand.name}`}>
          <img class="footer-logo" src={logoSrc} alt="MC2 TEK" />
        </a>
        <p class="footer-tagline">Ingegneria integrata per impianti affidabili, efficienti e realizzabili.</p>
        <div class="footer-socials" aria-label="Profili social">
          {site.footer.socials.map((social) => (
            <a class="footer-social-link" href={social.href} target="_blank" rel="noreferrer" aria-label={social.label}>
              {social.label === "LinkedIn" ? (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.4 8.2H3.2V20h3.2V8.2Zm.2-3.7A1.8 1.8 0 1 0 3 4.5a1.8 1.8 0 0 0 3.6 0ZM20.8 13.2c0-3.6-1.9-5.3-4.5-5.3a4 4 0 0 0-3.6 2v-1.7H9.5V20h3.2v-5.8c0-1.5.3-3 2.2-3 1.9 0 1.9 1.8 1.9 3.1V20H20v-6.8Z" />
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle class="instagram-dot" cx="17.5" cy="6.5" r="1"></circle>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <div class="footer-column footer-company">
        <span class="footer-label">Studio</span>
        <strong>{site.brand.legalName}</strong>
        <p>P. IVA {site.brand.vat}</p>
        <a href={site.brand.mapsUrl} target="_blank" rel="noreferrer">{site.brand.address}</a>
        <a href={`mailto:${site.brand.email}`}>{site.brand.email}</a>
        <a href={`tel:${site.brand.phone.replaceAll("/", "")}`}>T {site.brand.phone}</a>
        <a href={`tel:${site.brand.mobile.replaceAll("-", "")}`}>M {site.brand.mobile}</a>
      </div>

      <div class="footer-column footer-links">
        <span class="footer-label">Esplora</span>
        <nav class="footer-nav" aria-label="Navigazione nel footer">
          {site.nav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
        <div class="footer-legal">
          {site.footer.notes.map((note) => (
            <span>{note}</span>
          ))}
        </div>
        <p class="footer-credit">
          &copy; {currentYear} MC2 TEK<br />
          Realizzato da <a href="https://q4.studio" target="_blank" rel="noreferrer">Q4 Studio</a>
        </p>
      </div>
    </div>
  </footer>
</BaseLayout>
