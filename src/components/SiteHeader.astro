---
const { brand, nav } = Astro.props;
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand-lockup" href="#top" aria-label={`Vai all'inizio di ${brand.name}`}>
      <img class="brand-mark" src="https://stcpi.com/wp-content/uploads/2025/08/LOGO-MC2-TEK2-1.png" alt="MC2 TEK logo" />
    </a>

    <nav class="main-nav" aria-label="Navigazione principale">
      {nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="button button-ghost header-cta" href="#contatti">Contattaci</a>
  </div>
</header>
