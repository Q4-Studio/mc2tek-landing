---
const { brand, nav, logoSrc } = Astro.props;
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand-lockup" href="#top" aria-label={`Vai all'inizio di ${brand.name}`}>
      <img class="brand-mark" src={logoSrc} alt="MC2 TEK logo" />
    </a>

    <nav class="main-nav" aria-label="Navigazione principale">
      {nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="button header-cta" href="#contatti">Contattaci</a>
  </div>
</header>
